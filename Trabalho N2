#include <stdio.h>
#include <stdlib.h>
#include <time.h>     

#define PRODUTOS 200
#define CLIENTES 50


int num_aleatorio(int n)
{
    if (n <= 0) return 0;
    return rand() % n;
}

int main()
{
    int i, npro, ncli;
    float preco[PRODUTOS];
    int compra[CLIENTES];
    float total = 0.0;

    
    srand((unsigned)time(NULL));

    
    npro = num_aleatorio(PRODUTOS) + 1;

    for (i = 0; i < npro; i++)
    {
        preco[i] = 5.0 + num_aleatorio(96); 
    }

    
    ncli = num_aleatorio(CLIENTES) + 1;

    
    for (i = 0; i < ncli; i++)
    {
        
        compra[i] = num_aleatorio(npro);
        total += preco[compra[i]];
    }

    
    printf("Simulacao para:\n");
    printf("  %d produtos\n", npro);
    printf("  %d clientes\n", ncli);
    printf("-------------------------------------\n");
    printf("Cliente   Produto   Valor (R$)\n");
    printf("-------------------------------------\n");

    for (i = 0; i < ncli; i++)
    {
        
        printf("  %2d        %3d        %6.2f\n", i, compra[i], preco[compra[i]]);
    }

    printf("-------------------------------------\n");
    printf("TOTAL DE VENDAS         %7.2f\n", total);

    return 0;
}
    
