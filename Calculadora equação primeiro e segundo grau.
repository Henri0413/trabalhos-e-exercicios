#include <stdio.h>
#include <math.h>
#include <stdlib.h>

/* usado para não dar loop ao digitar uma letra */
void limparBuffer() {
    int c;
    while ((c = getchar()) != '\n' && c != EOF);
}

/* * Função para resolver e exibir o passo a passo de uma Equação do 1º Grau */
void resolverPrimeiroGrau() {
    float a, b, x;

    printf("\n=== Resolucao passo-a-passo: Equacao do Primeiro Grau ===\n");
    printf("Forma: ax + b = 0\n");
    
    printf("Digite o valor de a: ");
    if (scanf("%f", &a) != 1) {
        printf("Entrada invalida. Cancelando operacao.\n");
        limparBuffer();
        return;
    }
    
    printf("Digite o valor de b: ");
    if (scanf("%f", &b) != 1) {
        printf("Entrada invalida. Cancelando operacao.\n");
        limparBuffer();
        return;
    }

    /* Validação para garantir que é uma equação do 1º grau válida */
    if (a == 0) {
        if (b == 0) {
            printf("\nSe 'a' e 'b' sao zero, temos 0 = 0. A equacao tem infinitas solucoes (Sistema Possivel e Indeterminado).\n\n");
        } else {
            printf("\nSe 'a' e zero e 'b' e diferente de zero, temos uma impossibilidade matematica (%g = 0). Sem solucao (Sistema Impossivel).\n\n", b);
        }
        return;
    }

    printf("\nEquacao informada: %g x %s %g = 0\n", a, (b >= 0 ? "+" : "-"), (b >= 0 ? b : -b));
    printf("\nPassos:\n");
    
    /* Passo 1: Montagem da equação */
    printf("1)  (%g) x + (%g) = 0\n", a, b);
    
    /* Passo 2: Isolamento algébrico */
    printf("2)  (%g) x = -(%g)\n", a, b);
    printf("   ou: %g x = %g\n", a, -b);
    
    /* Passo 3: Divisão para encontrar a incógnita  */
    printf("3) Dividir ambos os lados por a: x = (%g) / (%g)\n", -b, a);
    
    /* Passo 4: Cálculo final */
    x = -b / a;
    printf("4) Calculo: x = %g\n", x);
    
    printf("\nSolucao: x = %g\n\n", x);
}

/* * Função para resolver e exibir o passo a passo de uma Equação do 2º Grau
 *ax^2 + bx + c = 0
 */
void resolverSegundoGrau() {
    
    float a, b, c;
    float delta, b2, quatro_ac, sqrt_delta, denominador;
    float x1, x2;
    float parteReal, parteImaginaria; /* Variáveis para raízes complexas */

    printf("\n=== Resolucao passo-a-passo: Equacao do Segundo Grau ===\n");
    printf("Forma: ax^2 + bx + c = 0\n");
    
    printf("Digite o valor de a: ");
    if (scanf("%f", &a) != 1) {
        printf("Entrada invalida. Cancelando operacao.\n");
        limparBuffer();
        return;
    }
    printf("Digite o valor de b: ");
    if (scanf("%f", &b) != 1) {
        printf("Entrada invalida. Cancelando operacao.\n");
        limparBuffer();
        return;
    }
    printf("Digite o valor de c: ");
    if (scanf("%f", &c) != 1) {
        printf("Entrada invalida. Cancelando operacao.\n");
        limparBuffer();
        return;
    }

    
    if (a == 0) {
        printf("\nSe 'a' for igual a zero, a equacao torna-se do 1o grau. Por favor, use a opcao 1 do menu.\n\n");
        return;
    }

    printf("\nEquacao informada: %g x^2 %s %g x %s %g = 0\n", 
           a, (b >= 0 ? "+" : "-"), (b >= 0 ? b : -b), (c >= 0 ? "+" : "-"), (c >= 0 ? c : -c));
    printf("\nPassos:\n");
    
    /* Passo 1: Cálculo do Discriminante (Delta) */
    b2 = b * b;
    quatro_ac = 4 * a * c;
    delta = b2 - quatro_ac;
    
    printf("1) Calcular o discriminante: Delta = b^2 - 4*a*c\n");
    printf("   - b^2 = (%g)^2 = %g\n", b, b2);
    printf("   - 4*a*c = 4 * (%g) * (%g) = %g\n", a, c, quatro_ac);
    printf("   -> Delta = %g - (%g) = %g\n", b2, quatro_ac, delta);
    
    denominador = 2 * a;

    /* Passo 2: Análise do Discriminante */
    if (delta > 0) {
        sqrt_delta = sqrt(delta);
        printf("\n2) Como Delta > 0, existem duas raizes reais distintas.\n");
        printf("   - sqrt(Delta) = sqrt(%g) = %g\n", delta, sqrt_delta);
        printf("   - Denominador 2a = 2 * (%g) = %g\n", a, denominador);
        
        /* Passo 3: Cálculo da primeira raiz */
        x1 = (-b + sqrt_delta) / denominador;
        printf("\n3) Calculo de x1:\n");
        printf("   x1 = (-b + sqrt(Delta)) / (2a)\n");
        printf("      = (-(%g) + %g) / %g\n", b, sqrt_delta, denominador);
        printf("      = %g / %g = %g\n", (-b + sqrt_delta), denominador, x1);
        
        /* Passo 4: Cálculo da segunda raiz */
        x2 = (-b - sqrt_delta) / denominador;
        printf("\n4) Calculo de x2:\n");
        printf("   x2 = (-b - sqrt(Delta)) / (2a)\n");
        printf("      = (-(%g) - %g) / %g\n", b, sqrt_delta, denominador);
        printf("      = %g / %g = %g\n", (-b - sqrt_delta), denominador, x2);
        
        printf("\nSolucoes reais: x1 = %g ; x2 = %g\n\n", x1, x2);

    } else if (delta == 0) {
        printf("\n2) Como Delta = 0, existe apenas uma raiz real (ou duas raizes iguais).\n");
        printf("   - Denominador 2a = 2 * (%g) = %g\n", a, denominador);
        
        x1 = -b / denominador;
        printf("\n3) Calculo de x:\n");
        printf("   x = -b / (2a)\n");
        printf("     = -(%g) / %g\n", b, denominador);
        printf("     = %g / %g = %g\n", -b, denominador, x1);
        
        printf("\nSolucao real: x = %g\n\n", x1);

    } else {
        /* Caso com raízes complexas (Delta < 0) */
        parteReal = -b / denominador;
        parteImaginaria = sqrt(-delta) / denominador; /* Usa -delta para ficar positivo no sqrt */

        printf("\n2) Como Delta < 0, as raizes sao complexas conjugadas.\n");
        printf("   - sqrt(|Delta|) = sqrt(%g) = %g\n", -delta, sqrt(-delta));
        printf("   - Denominador 2a = 2 * (%g) = %g\n", a, denominador);
        
        printf("\n3) Calculo das raizes complexas (x = Parte Real +/- Parte Imaginaria * i):\n");
        printf("   Parte Real = -b / 2a = -(%g) / %g = %g\n", b, denominador, parteReal);
        printf("   Parte Imaginaria = sqrt(|Delta|) / 2a = %g / %g = %g\n", sqrt(-delta), denominador, parteImaginaria);
        
        
        printf("\nSolucoes complexas: x1 = %g + %gi ; x2 = %g - %gi\n\n", 
               parteReal, fabs(parteImaginaria), parteReal, fabs(parteImaginaria));
    }
}

/* * Função principal: Controla o menu e a execução do programa
 */
int main() {
    int opcao;

    do {
        printf("=== MENU PRINCIPAL ===\n");
        printf("1 - Resolver equacao do primeiro grau (mostrar passos)\n");
        printf("2 - Resolver equacao do segundo grau (mostrar passos)\n");
        printf("0 - Sair\n");
        printf("Escolha uma opcao: ");
        
        /* Verifica se o usuário digitou um número válido */
        if (scanf("%d", &opcao) != 1) {
            printf("\nOpcao invalida. Por favor, digite um numero inteiro.\n\n");
            limparBuffer();
            opcao = -1; /* Força o loop a continuar */
            continue;
        }

        switch (opcao) {
            case 1:
                resolverPrimeiroGrau();
                break;
            case 2:
                resolverSegundoGrau();
                break;
            case 0:
                printf("\nEncerrando o programa.\n");
                break;
            default:
                printf("\nOpcao invalida! Escolha 1, 2 ou 0.\n\n");
        }
    } while (opcao != 0);

    return 0;
}
